[Script]
# 拦截查询 VIP 状态的接口，并执行 GitHub 上的远程脚本
http-response ^https:\/\/(api|api-cs)-cn\.intsig\.net\/purchase\/cs\/query_property script-path=https://raw.githubusercontent.com/GLH08/Script/main/Loon/CamScanner.js, requires-body=true, tag=全能扫描王VIP

[MITM]
# 声明需要解密的域名
hostname = ap*.intsig.net
